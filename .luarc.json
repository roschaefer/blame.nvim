{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "path": [
      "?.lua",
      "?/init.lua",
      "lua/?.lua",
      "lua/?/init.lua"
    ]
  },
  "diagnostics": {
    "globals": [
      "vim"
    ]
  },
  "workspace": {
    "checkThirdParty": false,
    "library": [
      "$VIMRUNTIME",
      "${3rd}/busted/library",
      "${3rd}/luassert/library",
      ".tests/data/nvim/lazy/nui.nvim/lua"
    ]
  },
  "files": {
    "exclude": [
      "tests/minit-test.lua",
      ".git"
    ]
  }
}
